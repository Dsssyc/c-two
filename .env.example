# ============================================================================
# C-Two Environment Variables
# ============================================================================
# Copy to `.env` and uncomment/edit as needed.
# Priority chain: explicit code (cc.set_*) > env vars / .env > defaults
# Set C2_ENV_FILE="" to disable .env loading entirely.
# ============================================================================

# Relay URL for CRM registration and client name resolution
# C2_RELAY_ANCHOR_ADDRESS=http://127.0.0.1:8080

# Relay-aware client route acquisition attempts before reporting failure
# (default: 3; valid range 1..=32; 0 is treated as 1)
# C2_RELAY_ROUTE_MAX_ATTEMPTS=3

# Relay HTTP CRM call timeout in seconds (default: 300; 0 disables reqwest total timeout)
# C2_RELAY_CALL_TIMEOUT=300

# --------------------------------------------------------------------------
# Remote Transport
# --------------------------------------------------------------------------

# Target C-Two remote payload chunk size in bytes
# (default: 1048576 = 1 MB; valid range 1..=134217728 = 128 MB).
# Shared by relay HTTP today and intended for future TCP / HTTP2 remote
# transports. This controls C-Two payload batching, not concrete TCP packets,
# HTTP/1 chunk boundaries, or HTTP/2 DATA frame sizes.
# C2_REMOTE_PAYLOAD_CHUNK_SIZE=1048576

# --------------------------------------------------------------------------
# Relay Server (c3 relay)
# --------------------------------------------------------------------------

# Bind address for the relay HTTP server  (default: 0.0.0.0:8080)
# C2_RELAY_BIND=0.0.0.0:8080

# Stable relay identifier for mesh protocol (auto-generated if unset)
# C2_RELAY_ID=relay-east-1

# Publicly reachable URL announced to mesh peers
# C2_RELAY_ADVERTISE_URL=http://relay-east-1.example.com:8080

# Comma-separated seed relay URLs for mesh mode
# C2_RELAY_SEEDS=http://relay-a:8080,http://relay-b:8080

# Idle upstream IPC connection timeout in seconds (default: 60; use 0 to disable time-based eviction)
# C2_RELAY_IDLE_TIMEOUT=60

# Anti-entropy digest exchange interval in seconds (default: 60.0)
# C2_RELAY_ANTI_ENTROPY_INTERVAL=60.0

# Whether c-two relay traffic should honor system HTTP_PROXY / HTTPS_PROXY
# env vars. Default: false (relay is private mesh infrastructure; proxies
# can corrupt %2F in URL path segments and leak control data).
# Set to 1/true to opt in.
# C2_RELAY_USE_PROXY=0

# --------------------------------------------------------------------------
# Shared Memory (SHM)
# --------------------------------------------------------------------------

# Payload size threshold for SHM vs inline transfer in bytes (default: 4096)
# C2_SHM_THRESHOLD=4096

# --------------------------------------------------------------------------
# IPC Memory Pool
# --------------------------------------------------------------------------

# Buddy pool segment size in bytes (default: 268435456 = 256 MB)
# C2_IPC_POOL_SEGMENT_SIZE=268435456

# Max buddy pool segments, range 1–255 (default: 4)
# C2_IPC_MAX_POOL_SEGMENTS=4

# Idle segment decay time in seconds (default: 60.0)
# C2_IPC_POOL_DECAY_SECONDS=60.0

# Enable/disable SHM pool (default: true)
# C2_IPC_POOL_ENABLED=true

# --------------------------------------------------------------------------
# IPC Frame / Payload Limits
# --------------------------------------------------------------------------

# Max inline frame size in bytes (default: 2147483648 = 2 GB)
# C2_IPC_MAX_FRAME_SIZE=2147483648

# Max single-call payload size in bytes (default: 17179869184 = 16 GB)
# C2_IPC_MAX_PAYLOAD_SIZE=17179869184

# Max concurrent pending requests per connection (default: 1024)
# C2_IPC_MAX_PENDING_REQUESTS=1024

# Max blocking execution workers for resource callbacks
# (default: host parallelism clamped to 4..64)
# C2_IPC_MAX_EXECUTION_WORKERS=8

# --------------------------------------------------------------------------
# IPC Heartbeat
# --------------------------------------------------------------------------

# Heartbeat interval in seconds, 0 disables (default: 15.0)
# C2_IPC_HEARTBEAT_INTERVAL=15.0

# Heartbeat timeout in seconds (default: 30.0)
# C2_IPC_HEARTBEAT_TIMEOUT=30.0

# --------------------------------------------------------------------------
# IPC Chunked Transfer
# --------------------------------------------------------------------------

# Max total in-flight chunks across all connections (default: 512)
# C2_IPC_MAX_TOTAL_CHUNKS=512

# Chunk GC sweep interval in seconds (default: 5.0)
# C2_IPC_CHUNK_GC_INTERVAL=5.0

# Chunk threshold ratio (fraction of max_frame_size to trigger chunking; default: 0.9)
# C2_IPC_CHUNK_THRESHOLD_RATIO=0.9

# Chunk assembler timeout in seconds (default: 60.0)
# C2_IPC_CHUNK_ASSEMBLER_TIMEOUT=60.0

# Max reassembly buffer memory in bytes (default: 8589934592 = 8 GB)
# C2_IPC_MAX_REASSEMBLY_BYTES=8589934592

# Individual chunk size in bytes (default: 131072 = 128 KB)
# C2_IPC_CHUNK_SIZE=131072

# --------------------------------------------------------------------------
# IPC Reassembly Pool
# --------------------------------------------------------------------------

# Reassembly pool segment size in bytes (default: 67108864 = 64 MB)
# C2_IPC_REASSEMBLY_SEGMENT_SIZE=67108864

# Max reassembly pool segments (default: 4)
# C2_IPC_REASSEMBLY_MAX_SEGMENTS=4
